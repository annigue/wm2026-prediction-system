# Backend — Produktions-Environment (Beispiel). Werte in Render als Secrets setzen.

# PostgreSQL — gleicher Host, ZWEI Treiber-Prefixe:
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/DBNAME
DATABASE_URL_SYNC=postgresql+psycopg2://USER:PASS@HOST:5432/DBNAME
# Extern/Managed mit SSL:  asyncpg -> ...?ssl=require   psycopg2 -> ...?sslmode=require

# Redis OPTIONAL — leer = ohne Cache (graceful degradation)
REDIS_URL=

# Externe APIs
ODDS_API_KEY=your-the-odds-api-key
RAPIDAPI_KEY=your-world-cup-2026-live-api-key

# Admin-Schutz für /api/v1/admin/* und POST /matches/{id}/result
ADMIN_TOKEN=change-me-long-random

ENV=production
MONTE_CARLO_RUNS=100000

# CORS: erlaubte Frontend-Origins (kommagetrennt)
CORS_ORIGINS=https://wm2026-frontend.onrender.com
